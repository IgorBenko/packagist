{% extends 'organization/layout.html.twig' %}

{% block title %}Invitations - {{ organization.displayName }} - {{ parent() }}{% endblock %}

{% set canInvite = is_granted(enum('App\\Security\\Voter\\OrganizationActions').InviteMember.value, organization) %}

{% block org_content %}
    <h3 class="title clearfix">
        Invitations
        {% if canInvite %}
            <a class="btn btn-success btn-sm pull-right" href="{{ path('organization_invitation_create', { organization: organization.slug }) }}">Invite a member</a>
        {% endif %}
    </h3>

    {% if invitations is empty %}
        <p>No invitations have been sent yet.</p>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Teams</th>
                    <th>Status</th>
                    <th>Last sent</th>
                    <th>Expires</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for row in invitations %}
                    {% set invitation = row.invitation %}
                    {% set effectiveStatus = invitation.effectiveStatus(now).value %}
                    <tr>
                        <td>{{ invitation.email }}</td>
                        <td class="team-labels">
                            {% for name in row.teamNames %}
                                <span class="label label-default">{{ name }}</span>
                            {% endfor %}
                        </td>
                        <td><span class="label label-{{ effectiveStatus == 'pending' ? 'info' : (effectiveStatus == 'accepted' ? 'success' : 'default') }}">{{ effectiveStatus }}</span></td>
                        <td>{{ invitation.lastSentAt|date('Y-m-d H:i') }}</td>
                        <td>{% if invitation.isActive(now) %}{{ invitation.expiresAt|date('Y-m-d H:i') }}{% endif %}</td>
                        {# btn-group-xs is the app's small-button hook (.btn-group-xs .btn); plain btn-xs is
                           overridden by the app's .btn padding. Each action is its own CSRF-protected form. #}
                        <td class="text-right btn-group-xs" style="white-space:nowrap">
                            {% if invitation.pending %}
                                <a class="btn btn-default" href="{{ path('organization_invitation_resend', { organization: organization.slug, invitation: invitation.id }) }}">Resend</a>
                                <form method="post" action="{{ path('organization_invitation_revoke', { organization: organization.slug, invitation: invitation.id }) }}" style="display:inline-block; margin-left:4px">
                                    <input type="hidden" name="_token" value="{{ csrf_token('invitation') }}">
                                    <button class="btn btn-danger" type="submit">Revoke</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}

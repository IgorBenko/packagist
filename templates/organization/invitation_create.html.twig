{% extends 'organization/layout.html.twig' %}

{% block title %}Invite a member - {{ organization.displayName }} - {{ parent() }}{% endblock %}

{% block org_content %}
    <h3 class="title">Invite a member</h3>

    {{ form_start(form, { 'attr': { 'class': 'organization_invitation_create' } }) }}
        {{ form_errors(form) }}
        <div class="form-group clearfix">
            {{ form_label(form.email) }}
            {{ form_errors(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_help(form.email) }}
        </div>
        <div class="form-group clearfix">
            {{ form_label(form.teamIds) }}
            {{ form_errors(form.teamIds) }}
            {% for team in form.teamIds %}
                <div class="checkbox">
                    <label>{{ form_widget(team) }} {{ team.vars.label }}</label>
                </div>
            {% endfor %}
            {{ form_help(form.teamIds) }}
        </div>
        <input class="btn btn-success" type="submit" value="Send invitation" />
        <a class="btn btn-default" href="{{ path('organization_invitations', { organization: organization.slug }) }}">Cancel</a>
    {{ form_end(form) }}
{% endblock %}
